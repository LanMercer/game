<%
/**
 * 单机游戏轨道
 * 
 * 筛选 track: single 的文章并渲染为卡片
 */

// 获取单机游戏文章（按日期正序）
const singlePosts = site.posts.filter(post => post.track === 'single').sort('date', 'asc');
%>

<section class="track track-single" data-track="single">
  <header class="track-header">
    <h2 class="track-title">单机游戏</h2>
    <p class="track-subtitle">独自探索的冒险旅程</p>
  </header>
  
  <div class="track-content">
    <% if (singlePosts.length === 0) { %>
      <div class="track-placeholder">
        <p>暂无单机游戏记录</p>
        <span>在 source/_posts/ 添加 track: single 的文章</span>
      </div>
    <% } else { %>
      <% singlePosts.forEach(post => { %>
        <%- partial('game-card', { post: post, track: 'single' }) %>
      <% }) %>
    <% } %>
  </div>
</section>
