<!-- Swiper JS -->
<% if (theme.theme.enable_swiper) { %>
<script src="<%= theme.cdn.swiper_js %>"></script>
<% } %>

<!-- 懒加载 -->
<script src="<%= theme.cdn.lazysizes %>" async></script>

<!-- 主题脚本 -->
<%- js('js/timeline-scroll') %>
<% if (theme.theme.enable_star_map) { %>
<%- js('js/star-map') %>
<% } %>
<% if (theme.theme.enable_lightbox) { %>
<%- js('js/lightbox') %>
<% } %>
<%- js('js/split-track') %>
<%- js('js/main') %>

<!-- Swiper 初始化 -->
<% if (theme.theme.enable_swiper) { %>
<script>
document.addEventListener('DOMContentLoaded', function() {
  // 初始化所有游戏相册
  document.querySelectorAll('.game-album').forEach(function(el) {
    new Swiper(el, {
      slidesPerView: 1,
      spaceBetween: 10,
      loop: true,
      pagination: {
        el: '.swiper-pagination',
        clickable: true
      },
      effect: 'fade',
      fadeEffect: {
        crossFade: true
      },
      // 自动播放（可选）
      autoplay: {
        delay: 3000,
        disableOnInteraction: true
      }
    });
  });
});
</script>
<% } %>
