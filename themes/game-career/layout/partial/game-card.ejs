<% 
/**
 * 游戏卡片组件
 * 
 * 参数：
 * - post: 文章对象
 * - track: 'single' | 'multi' 轨道类型
 */

// 安全获取数组/字符串字段
const getArray = (field) => {
  if (!field) return [];
  if (Array.isArray(field)) return field;
  if (typeof field === 'string') return field.split(',').map(s => s.trim()).filter(Boolean);
  return [];
};

// 获取 Hexo 标签对象（特殊处理）
const getTags = (tagsField) => {
  if (!tagsField) return [];
  // Hexo 的 tags 是 Query 对象，需要用 toArray() 或遍历
  if (tagsField.toArray) {
    return tagsField.toArray().map(t => t.name);
  }
  if (Array.isArray(tagsField)) {
    return tagsField.map(t => typeof t === 'object' ? t.name : t);
  }
  if (typeof tagsField === 'string') {
    return tagsField.split(',').map(s => s.trim()).filter(Boolean);
  }
  return [];
};

// 安全获取字符串
const getString = (field) => {
  if (!field) return '';
  return String(field);
};

const photos = getArray(post.photos);
const videos = getArray(post.videos);
const tags = getTags(post.tags);
const partners = getArray(post.partners);
const gameMoments = getArray(post.game_moments);
const gameId = getString(post.game_id);
%>

<article class="game-card" 
         data-game-id="<%= gameId %>"
         data-track="<%= track %>"
         id="<%= post.date.format('YYYY-MM') %>">
  
  <div class="card-header">
    <h3 class="game-title"><%= post.title.replace(/\s+\d{4}[\.\-]\d+.*$/, '') %></h3>
    <span class="game-date"><%= post.date.format('YYYY.MM') %></span>
  </div>
  
  <% if (post.description) { %>
    <p class="game-description"><%= post.description %></p>
  <% } %>
  
  <% if (photos.length > 0) { %>
    <div class="game-media">
      <% if (photos.length === 1) { %>
        <div class="media-single">
          <img src="<%= photos[0] %>" 
               data-src="<%= photos[0] %>"
               data-lightbox
               data-type="image"
               alt="<%= post.title %>"
               loading="lazy">
        </div>
      <% } else { %>
        <div class="swiper-container game-album" data-game="<%= gameId %>">
          <div class="swiper-wrapper">
            <% photos.forEach((photo, idx) => { %>
              <div class="swiper-slide">
                <img src="<%= photo %>"
                     data-src="<%= photo %>"
                     data-lightbox
                     data-gallery="<%= gameId %>"
                     data-type="image"
                     alt="<%= post.title %> - <%= idx + 1 %>"
                     loading="lazy">
              </div>
            <% }) %>
          </div>
          <div class="swiper-pagination"></div>
          <div class="album-badge"><%= photos.length %> 图</div>
        </div>
      <% } %>
    </div>
  <% } %>
  
  <% if (videos.length > 0) { %>
    <div class="game-videos">
      <% videos.forEach(video => { %>
        <div class="video-thumbnail" 
             data-lightbox
             data-src="<%= video %>"
             data-type="video">
          <span class="play-icon">▶</span>
          <span class="video-label">视频</span>
        </div>
      <% }) %>
    </div>
  <% } %>
  
  <div class="card-meta">
    <% if (post.platform) { %>
      <span class="meta-item platform"><%= post.platform %></span>
    <% } %>
    <% if (post.play_time) { %>
      <span class="meta-item playtime"><%= post.play_time %>h</span>
    <% } %>
    <% if (post.rating) { %>
      <span class="meta-item rating">
        <% for(let i = 0; i < post.rating; i++) { %>★<% } %>
      </span>
    <% } %>
  </div>
  
  <% if (tags.length > 0) { %>
    <div class="card-tags">
      <% tags.forEach(tag => { %>
        <span class="tag"><%= tag %></span>
      <% }) %>
    </div>
  <% } %>
  
  <% if (track === 'multi' && partners.length > 0) { %>
    <div class="game-partners">
      <span class="partners-label">与</span>
      <% partners.forEach((partner, idx) => { %>
        <span class="partner-name"><%= partner %></span>
        <%= idx < partners.length - 1 ? '、' : '' %>
      <% }) %>
      <span class="partners-label">一起</span>
    </div>
  <% } %>
  
  <% if (gameMoments.length > 0) { %>
    <div class="game-moments">
      <% gameMoments.forEach(moment => { %>
        <span class="moment-tag"><%= moment %></span>
      <% }) %>
    </div>
  <% } %>
  
  <a href="<%= url_for(post.path) %>" class="card-link">查看详情 →</a>
</article>