<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="theme-color" content="<%= theme.colors.bg_dark %>">

<title>
  <% if (page.title) { %>
    <%= page.title %> | <%= config.title %>
  <% } else { %>
    <%= config.title %>
    <% if (config.subtitle) { %> - <%= config.subtitle %><% } %>
  <% } %>
</title>

<meta name="description" content="<%= page.description || config.description %>">

<!-- 字体 -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Noto+Sans+SC:wght@300;400;500;600&display=swap" rel="stylesheet">

<!-- Swiper CSS -->
<% if (theme.theme.enable_swiper) { %>
<link rel="stylesheet" href="<%= theme.cdn.swiper_css %>">
<% } %>

<!-- 主题样式 -->
<link rel="stylesheet" href="<%= url_for('/css/style.css') %>">

<!-- Favicon -->
<% if (theme.favicon) { %>
<link rel="icon" href="<%= url_for(theme.favicon) %>">
<% } %>
